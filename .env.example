# ── Google ADK / Gemini ───────────────────────────────────────────────────────
# Option A: Gemini via Google AI Studio (free tier available)
GOOGLE_API_KEY=your-google-ai-studio-key

# Option B: Vertex AI (requires GCP project)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── Model ─────────────────────────────────────────────────────────────────────
# Gemini options: gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash
# LiteLLM options: ollama/llama3 | ollama/mistral | anthropic/claude-3-5-sonnet
MODEL_ID=gemini-2.0-flash

# ── Research Tools (all free / open-source) ───────────────────────────────────
# DuckDuckGo search: no key needed
# OpenCorporates: no key needed for basic search (free tier)
# GitHub: optional — increases rate limits for org member lookups
GITHUB_TOKEN=

# ── CRM: Salesforce ───────────────────────────────────────────────────────────
# Use a Connected App OAuth2 flow to obtain these values
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# ── CRM: HubSpot ──────────────────────────────────────────────────────────────
# Generate a Private App token in HubSpot Settings → Integrations → Private Apps
HUBSPOT_API_KEY=

# ── Anthropic (optional — for Claude-based sub-agents via LiteLLM) ────────────
ANTHROPIC_API_KEY=

# ── Product Engineering Pipeline ──────────────────────────────────────────────
# GitHub personal access token with repo scope
GITHUB_TOKEN=your_github_personal_access_token
# Vercel API token
VERCEL_TOKEN=your_vercel_api_token
# Railway API token
RAILWAY_TOKEN=your_railway_api_token
# NeonDB API key
NEONDB_API_KEY=your_neondb_api_key
# Supabase Management API access token
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# ── Medium MCP Server ─────────────────────────────────────────────────────────
# Path to the cloned + built medium-mcp-server repo
# Setup: git clone https://github.com/jackyckma/medium-mcp-server.git
#        cd medium-mcp-server && npm install && npx playwright install chromium && npm run build
# Session: run the server once manually to complete browser login (saves medium-session.json)
MEDIUM_MCP_PATH=../medium-mcp-server

